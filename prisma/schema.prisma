generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Service {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  duration    Int
  price       String
  image       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
}

model Photographer {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  bio       String?
  image     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  bookings  Booking[]
}

model Booking {
  id              Int       @id @default(autoincrement())
  clientName      String
  clientEmail     String
  clientPhone     String
  notes           String    @default("")
  bookingDate     String
  startTime       String
  endTime         String
  totalPrice      String
  status          String    @default("confirmed")
  createdAt       DateTime  @default(now())
  serviceId       Int
  photographerId  Int
  service         Service   @relation(fields: [serviceId], references: [id])
  photographer    Photographer @relation(fields: [photographerId], references: [id])
}

model EventTemplate {
  id                Int       @id @default(autoincrement())
  typeId            String    @unique
  name              String
  tagline           String    @default("")
  description       String    @default("")
  icon              String    @default("heart")
  isActive          Boolean   @default(true)
  defaultMaxReels   Int       @default(3)
  defaultReelPrice  Int       @default(6000)
  coverageOptions   String    @default("[]")
  addOnOptions      String    @default("[]")
  defaultPrices     String    @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  subEvents         SubEvent[]
}

model SubEvent {
  id              Int       @id @default(autoincrement())
  subEventId      String
  name            String
  description     String    @default("")
  defaultSelected Boolean   @default(false)
  maxReels        Int?
  sortOrder       Int       @default(0)
  priceOverrides  String    @default("{}")
  templateId      Int
  template        EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([subEventId, templateId])
}

model EstimateLead {
  id          Int      @id @default(autoincrement())
  clientName  String
  clientPhone String
  eventType   String
  eventName   String   @default("")
  estimateData String  @default("{}")
  createdAt   DateTime @default(now())
}
